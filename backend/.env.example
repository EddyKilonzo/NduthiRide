# ── App ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nduthiride

# ── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-a-different-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Lipana (M-Pesa STK Push) ───────────────────────────────────
# Get these from your Lipana dashboard: https://lipana.co.ke
LIPANA_SECRET_KEY=lip_sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LIPANA_PUBLISHABLE_KEY=lip_pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret — set this in Lipana dashboard and copy it here
LIPANA_WEBHOOK_SECRET=your-lipana-webhook-secret

# ── CORS / Frontend URL ────────────────────────────────────────
# Your deployed Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
# Or for multiple origins:
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com

# ── Cloudinary (profile photos, proof-of-delivery images) ─────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Africa's Talking SMS ───────────────────────────────────────
SMS_API_KEY=your-at-api-key
SMS_USERNAME=your-at-username
SMS_SENDER_ID=NduthiRide

# ── Email (SMTP) ───────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-smtp-user
MAIL_PASS=your-smtp-password
MAIL_FROM_NAME=NduthiRide
MAIL_FROM_ADDRESS=no-reply@nduthiride.co.ke

# ── Firebase (push notifications) ─────────────────────────────
# Paste the full service-account JSON as a single-line base64 string:
# cat firebase-service-account.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT=
