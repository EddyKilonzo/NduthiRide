# ─────────────────────────────────────────────────────────────
# NduthiRide — Environment Variables Template
# Copy this to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# ── Database (PostgreSQL) ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nduthiride?schema=public

# ── JWT Auth ─────────────────────────────────────────────────
# Use long, random strings — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── M-Pesa (Lipana API) ────────────────────────────────────
# Get your keys from https://lipana.dev/dashboard
# Use test keys for development, live keys for production
LIPANA_SECRET_KEY=lip_sk_test_YOUR_SECRET_KEY
LIPANA_WEBHOOK_SECRET=your_webhook_secret_here
# Lipana API Base URL (do not change)
LIPANA_API_URL=https://api.lipana.dev/v1

# ── Mapbox ───────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# ── Cloudinary (image uploads) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SMS (Africa's Talking or similar) ───────────────────────
SMS_API_KEY=your_sms_api_key
SMS_USERNAME=your_sms_username
SMS_SENDER_ID=NduthiRide
