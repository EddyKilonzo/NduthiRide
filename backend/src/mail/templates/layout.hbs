<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{subject}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0A0A0A;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #F0F0F0;
      padding: 40px 16px;
    }
    .wrapper { max-width: 580px; margin: 0 auto; }
    .header {
      text-align: center;
      padding: 0 0 32px;
    }
    .logo {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }
    .logo-icon { font-size: 28px; }
    .logo-text {
      font-size: 22px;
      font-weight: 700;
      color: #FF6B00;
      letter-spacing: -0.5px;
    }
    .card {
      background: #141414;
      border: 1px solid #2A2A2A;
      border-radius: 16px;
      padding: 40px 36px;
    }
    .footer {
      text-align: center;
      padding: 28px 0 0;
      font-size: 12px;
      color: #555;
      line-height: 1.7;
    }
    .footer a { color: #FF6B00; text-decoration: none; }
    h1 {
      font-size: 24px;
      font-weight: 700;
      color: #F0F0F0;
      margin-bottom: 8px;
    }
    h2 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 12px;
    }
    p {
      font-size: 15px;
      color: #AAAAAA;
      line-height: 1.7;
      margin-bottom: 16px;
    }
    p:last-child { margin-bottom: 0; }
    .divider {
      border: none;
      border-top: 1px solid #2A2A2A;
      margin: 28px 0;
    }
    .btn {
      display: inline-block;
      background: #FF6B00;
      color: #ffffff !important;
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 0.2px;
      margin: 8px 0;
    }
    .btn:hover { background: #FF8C33; }
    .info-row {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid #2A2A2A;
      font-size: 14px;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label { color: #888888; }
    .info-value { font-weight: 600; color: #F0F0F0; }
    .otp-box {
      background: #1E1E1E;
      border: 1px solid #FF6B00;
      border-radius: 12px;
      text-align: center;
      padding: 24px;
      margin: 24px 0;
    }
    .otp-code {
      font-size: 40px;
      font-weight: 700;
      letter-spacing: 10px;
      color: #FF6B00;
    }
    .otp-expiry {
      font-size: 13px;
      color: #888;
      margin-top: 8px;
    }
    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-success { background: rgba(34,197,94,.15); color: #22C55E; }
    .badge-warning { background: rgba(245,158,11,.15); color: #F59E0B; }
    .badge-info    { background: rgba(59,130,246,.15);  color: #3B82F6; }
    .alert {
      background: rgba(255,107,0,.08);
      border: 1px solid rgba(255,107,0,.25);
      border-radius: 10px;
      padding: 14px 18px;
      font-size: 13px;
      color: #AAAAAA;
      margin: 20px 0;
    }
    .alert strong { color: #FF6B00; }
    .fare-total {
      font-size: 28px;
      font-weight: 700;
      color: #FF6B00;
      margin: 8px 0;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <div class="logo">
        <span class="logo-icon">🏍</span>
        <span class="logo-text">NduthiRide</span>
      </div>
    </div>

    <div class="card">
      {{{body}}}
    </div>

    <div class="footer">
      <p>
        © {{year}} NduthiRide · Nairobi, Kenya<br />
        <a href="#">Unsubscribe</a> &nbsp;·&nbsp; <a href="#">Privacy Policy</a> &nbsp;·&nbsp; <a href="#">Terms of Service</a>
      </p>
      <p style="margin-top:12px; color:#333;">
        This email was sent to <strong style="color:#555;">{{recipientEmail}}</strong>.<br />
        If you did not create an account, please ignore this email.
      </p>
    </div>
  </div>
</body>
</html>
