<!-- Heading -->
<h1 style="margin:0 0 8px;font-size:24px;font-weight:700;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;line-height:1.3;">
  Verify your email
</h1>

<p style="margin:0 0 16px;font-size:15px;color:#AAAAAA;line-height:1.7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  Hi <strong style="color:#F0F0F0;font-weight:600;">{{fullName}}</strong>,
</p>

<p style="margin:0 0 20px;font-size:15px;color:#AAAAAA;line-height:1.7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  Use the one-time code below to verify your email address.
  The code expires in <strong style="color:#F0F0F0;font-weight:600;">{{expiresMins}} minutes</strong>.
</p>

<!-- OTP box -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 24px;">
  <tr>
    <td align="center" style="background-color:#1A2E26;border:2px solid #408A71;border-radius:14px;padding:28px 24px;">
      <p style="margin:0 0 10px;font-size:48px;font-weight:800;letter-spacing:14px;color:#408A71;font-family:'Courier New',Courier,monospace;line-height:1;">
        {{otp}}
      </p>
      <p style="margin:0;font-size:13px;color:#777777;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
        Valid for {{expiresMins}} minutes &nbsp;&middot;&nbsp; Do not share this code
      </p>
    </td>
  </tr>
</table>

<p style="margin:0 0 20px;font-size:15px;color:#AAAAAA;line-height:1.7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  Enter this code in the NduthiRide app to confirm your email address.
</p>

<!-- Alert box -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 20px;">
  <tr>
    <td style="background-color:rgba(64,138,113,0.08);border:1px solid rgba(64,138,113,0.3);border-radius:10px;padding:14px 18px;">
      <p style="margin:0;font-size:13px;color:#AAAAAA;line-height:1.6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
        <strong style="color:#408A71;">Didn't request this?</strong>
        Someone may have entered your email by mistake.
        You can safely ignore this email — your account is not at risk.
      </p>
    </td>
  </tr>
</table>

<!-- Divider -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:20px 0;">
  <tr>
    <td style="border-top:1px solid #2A2A2A;font-size:0;line-height:0;">&nbsp;</td>
  </tr>
</table>

<p style="margin:0;font-size:13px;color:#555555;text-align:center;line-height:1.6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  For your security, NduthiRide staff will <strong style="color:#777777;">never</strong> ask for this code.
</p>
