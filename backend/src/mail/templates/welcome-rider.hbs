<!-- Heading -->
<h1 style="margin:0 0 8px;font-size:24px;font-weight:700;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;line-height:1.3;">
  Rider Application Received
</h1>

<p style="margin:0 0 12px;font-size:15px;color:#AAAAAA;line-height:1.7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  Hi <strong style="color:#F0F0F0;font-weight:600;">{{fullName}}</strong>,
</p>

<p style="margin:0 0 20px;font-size:15px;color:#AAAAAA;line-height:1.7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  Thank you for signing up as a NduthiRide rider. Your application has been received
  and is currently under review.
</p>

<!-- Divider -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 20px;">
  <tr><td style="border-top:1px solid #2A2A2A;font-size:0;line-height:0;">&nbsp;</td></tr>
</table>

<h2 style="margin:0 0 14px;font-size:16px;font-weight:600;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Application Summary</h2>

<!-- Info rows -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
  <tr>
    <td style="padding:12px 0;border-bottom:1px solid #2A2A2A;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
        <tr>
          <td style="font-size:14px;color:#888888;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">License Number</td>
          <td align="right" style="font-size:14px;font-weight:600;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">{{licenseNumber}}</td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding:12px 0;border-bottom:1px solid #2A2A2A;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
        <tr>
          <td style="font-size:14px;color:#888888;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Bike Registration</td>
          <td align="right" style="font-size:14px;font-weight:600;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">{{bikeRegistration}}</td>
        </tr>
      </table>
    </td>
  </tr>
  {{#if bikeModel}}
  <tr>
    <td style="padding:12px 0;border-bottom:1px solid #2A2A2A;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
        <tr>
          <td style="font-size:14px;color:#888888;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Bike Model</td>
          <td align="right" style="font-size:14px;font-weight:600;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">{{bikeModel}}</td>
        </tr>
      </table>
    </td>
  </tr>
  {{/if}}
  <tr>
    <td style="padding:12px 0;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
        <tr>
          <td style="font-size:14px;color:#888888;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Status</td>
          <td align="right">
            <span style="display:inline-block;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;background:rgba(245,158,11,0.15);color:#F59E0B;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">Pending Verification</span>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Divider -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:20px 0;">
  <tr><td style="border-top:1px solid #2A2A2A;font-size:0;line-height:0;">&nbsp;</td></tr>
</table>

<h2 style="margin:0 0 10px;font-size:16px;font-weight:600;color:#F0F0F0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">What happens next?</h2>

<p style="margin:0 0 16px;font-size:15px;color:#AAAAAA;line-height:1.7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  Our team will verify your license and bike documents within <strong style="color:#F0F0F0;">24&#8211;48 hours</strong>.
  You will receive an email as soon as your account is approved.
</p>

<!-- Alert -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 24px;">
  <tr>
    <td style="background-color:rgba(64,138,113,0.08);border:1px solid rgba(64,138,113,0.3);border-radius:10px;padding:14px 18px;">
      <p style="margin:0;font-size:13px;color:#AAAAAA;line-height:1.6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
        <strong style="color:#408A71;">Note:</strong> Make sure your license and bike registration are valid and up to date.
        Applications with expired documents will be rejected.
      </p>
    </td>
  </tr>
</table>

<!-- CTA button -->
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
  <tr>
    <td align="center">
      <a href="{{appUrl}}" style="display:inline-block;background-color:#408A71;color:#ffffff;text-decoration:none;padding:14px 36px;border-radius:10px;font-size:15px;font-weight:600;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;letter-spacing:0.2px;">
        Open Rider App
      </a>
    </td>
  </tr>
</table>
