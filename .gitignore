# ── Root .gitignore for NduthiRide monorepo ──────────────────

# Dependencies
node_modules/

# Environment — NEVER commit secrets
.env
.env.local
.env.*.local

# Build output
dist/
build/
*.tsbuildinfo

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Prisma generated client
generated/

# Accidental tsc output beside prisma/seed.ts (use ts-node / prisma seed, not committed JS)
backend/prisma/seed.js
backend/prisma/seed.js.map
backend/prisma/seed.d.ts

# Test coverage
coverage/
